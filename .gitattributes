# Keep repository text deterministic across Windows and Unix tooling.
* text=auto

*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.cpp text eol=lf
*.cc text eol=lf
*.c text eol=lf
*.h text eol=lf
*.rc text eol=crlf
*.manifest text eol=crlf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
